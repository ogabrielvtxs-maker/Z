{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the study platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "accessCFO": { "type": "boolean" },
        "accessSoldado": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "plan": { "type": "string" },
        "planEndDate": { "type": "string" }
      },
      "required": ["id", "name", "email", "accessCFO", "accessSoldado", "isAdmin", "isApproved", "createdAt"]
    },
    "StudyCycle": {
      "title": "StudyCycle",
      "description": "Weekly study cycle assigned to a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "weekNumber": { "type": "number" },
        "days": { "type": "array" },
        "unlockedAt": { "type": "string" },
        "isCompleted": { "type": "boolean" }
      },
      "required": ["id", "studentId", "studentName", "weekNumber", "days", "unlockedAt", "isCompleted"]
    },
    "WeeklyReport": {
      "title": "WeeklyReport",
      "description": "Report sent to student's inbox (Correio)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "weekNumber": { "type": "number" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "studentId", "weekNumber", "content", "createdAt", "updatedAt"]
    },
    "ContentItem": {
      "title": "ContentItem",
      "description": "Shared video, PDF, or link item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" },
        "topic": { "type": "string" },
        "subtopic": { "type": "string" }
      },
      "required": ["id", "title", "subtitle", "type", "url", "category", "createdAt"]
    },
    "SyllabusProgress": {
      "title": "SyllabusProgress",
      "description": "The current vertical syllabus progress for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "sections": { "type": "array" },
        "updatedAt": { "type": "string" }
      },
      "required": ["studentId", "sections", "updatedAt"]
    },
    "PerformanceLog": {
      "title": "PerformanceLog",
      "description": "Individual performance logs tracking errors and stats for questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "reasonForError": { "type": "string" },
        "questionsAttempted": { "type": "number" },
        "questionsCorrect": { "type": "number" }
      },
      "required": ["id", "studentId", "date", "subject", "topic", "reasonForError", "questionsAttempted", "questionsCorrect"]
    },
    "CoordQuestion": {
      "title": "CoordQuestion",
      "description": "Inedited and previous exam questions uploaded by platforms coordinators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "options": { "type": "array" },
        "correctOptionIndex": { "type": "number" },
        "explanation": { "type": "string" },
        "createdAt": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string" },
        "year": { "type": "string" },
        "banca": { "type": "string" }
      },
      "required": ["id", "statement", "options", "correctOptionIndex", "explanation", "createdAt", "subject"]
    },
    "PrivateStudentNotes": {
      "title": "PrivateStudentNotes",
      "description": "Encrypted or private student study notes",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["studentId", "notes", "updatedAt"]
    },
    "PasswordResetRequest": {
      "title": "PasswordResetRequest",
      "description": "Password change/reset request from a student to the administrator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "name", "status", "createdAt"]
    },
    "StudyModule": {
      "title": "StudyModule",
      "description": "Learning module for course library",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Active users registered on the platform"
    },
    "/modules/{moduleId}": {
      "schema": "StudyModule",
      "description": "Admin created learning modules"
    },
    "/study_cycles/{studentId}": {
      "schema": "StudyCycle",
      "description": "Assigned study cycles of the student"
    },
    "/reports/{reportId}": {
      "schema": "WeeklyReport",
      "description": "Weekly feedback reports"
    },
    "/shared_content/{itemId}": {
      "schema": "ContentItem",
      "description": "Syllabus supplementary material or links shared by admins"
    },
    "/syllabus_progress/{studentId}": {
      "schema": "SyllabusProgress",
      "description": "Student's syllabus tracking checkpoints"
    },
    "/performance_logs_{studentId}/{logId}": {
      "schema": "PerformanceLog",
      "description": "Error tracking registers for the specified studentId"
    },
    "/coordination_questions/{questionId}": {
      "schema": "CoordQuestion",
      "description": "Coordination questions database"
    },
    "/private_student_notes/{studentId}": {
      "schema": "PrivateStudentNotes",
      "description": "Student private notes and diary"
    },
    "/password_reset_requests/{requestId}": {
      "schema": "PasswordResetRequest",
      "description": "Pending and completed password change requests"
    }
  }
}
